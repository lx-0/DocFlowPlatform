# Auth mode controls which login flow the frontend uses.
# Valid values: local | ldap | sso
# Default: local
#
#   local  — email/password form, submits to POST /api/auth/login
#   ldap   — email/password form, submits to POST /api/auth/ldap/login (Active Directory / LDAP)
#   sso    — single "Sign in with SSO" button, redirects to GET /api/auth/sso/login;
#            on callback the JWT is read from the ?token= query param
VITE_AUTH_MODE=local
